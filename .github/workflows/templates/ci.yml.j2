# Do not edit this file.
# This file is generated automatically by executing tox -e generate-workflows

name: CI

on:
  push:
    branches:
    - 'main'
  pull_request:

permissions:
  contents: read

concurrency:
  group: ${% raw %}{{ github.workflow }}-${{ github.head_ref || github.run_id }}{% endraw %}
  cancel-in-progress: true

jobs:
  {%- for n in range(misc_count) %}

  misc_{{ n }}:
    uses: ./.github/workflows/misc_{{ n }}.yml
  {%- endfor %}
  {%- for n in range(lint_count) %}

  lint_{{ n }}:
    uses: ./.github/workflows/lint_{{ n }}.yml
  {%- endfor %}
  {%- for n in range(test_count) %}

  tests_{{ n }}:
    uses: ./.github/workflows/test_{{ n }}.yml
  {%- endfor %}

  contrib_0:
    uses: open-telemetry/opentelemetry-python-contrib/.github/workflows/core_contrib_test_0.yml@main
    with:
      CORE_REPO_SHA: ${% raw %}{{ github.sha }}{% endraw %}
      CONTRIB_REPO_SHA: {% raw %}${{ github.event_name == 'pull_request' && (
          contains(github.event.pull_request.labels.*.name, 'prepare-release') && github.event.pull_request.head.ref ||
          contains(github.event.pull_request.labels.*.name, 'backport') && github.event.pull_request.base.ref ||
          'main'
        ) || 'main' }}{% endraw %}

  check:
    if: always()
    needs:
      {%- for n in range(misc_count) %}
      - misc_{{ n }}
      {%- endfor %}
      {%- for n in range(lint_count) %}
      - lint_{{ n }}
      {%- endfor %}
      {%- for n in range(test_count) %}
      - tests_{{ n }}
      {%- endfor %}
      - contrib_0
    runs-on: ubuntu-latest
    steps:
      - name: Decide whether the needed jobs succeeded or failed
        uses: re-actors/alls-green@release/v1
        with:
          allowed-failures: ""
          allowed-skips: ""
          jobs: ${% raw %}{{ toJSON(needs) }}{% endraw %}
